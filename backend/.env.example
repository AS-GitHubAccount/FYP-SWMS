# Rename to .env (same folder):  cp .env.example .env

# --- MySQL ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=swms_db

# Aiven / managed MySQL: use TLS. Put the service CA on the server (e.g. backend/certs/aiven-ca.pem).
# DB_SSL=true
# DB_SSL_CA=certs/aiven-ca.pem
# DB_SSL_REJECT_UNAUTHORIZED=true
# Quick test only (weaker): DB_SSL=true and DB_SSL_REJECT_UNAUTHORIZED=false

PORT=3000

# Base URL for links in emails (invites, password reset). Match however you serve the HTML.
# FRONTEND_BASE_URL=http://localhost:8080

# Don’t ship with the default — generate something long and random.
JWT_SECRET=change_this_to_a_long_random_string

# --- Email (optional) ---
# Without this, login still works; password reset / mail features just won’t send.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
