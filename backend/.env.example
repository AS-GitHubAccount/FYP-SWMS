# Rename to .env (same folder):  cp .env.example .env

# --- MySQL ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=swms_db

# Aiven: if DB_HOST ends with aivencloud.com and DB_NAME is unset, the app defaults to defaultdb and enables TLS.
# Railway: set DB_HOST, DB_PORT, DB_USER, DB_PASSWORD (and optional DB_NAME=defaultdb), redeploy after changes.

# Aiven / managed MySQL: use TLS. Put the service CA on the server (e.g. backend/certs/aiven-ca.pem).
# DB_SSL=true
# DB_SSL_CA=certs/aiven-ca.pem
# DB_SSL_REJECT_UNAUTHORIZED=true
# Quick test only (weaker): DB_SSL=true and DB_SSL_REJECT_UNAUTHORIZED=false

PORT=3000

# Base URL for links in invitation / set-password emails (must be the public https URL in production).
# Forgot-password emails only send a temp password (no link), so they can seem fine while invite links break if this is wrong.
# FRONTEND_BASE_URL=https://your-app.up.railway.app
# Railway: if unset, the server uses https://<RAILWAY_PUBLIC_DOMAIN> when Railway injects it.

# Don’t ship with the default — generate something long and random.
JWT_SECRET=change_this_to_a_long_random_string
# Access token lifetime (jsonwebtoken string, default 1d). Optional seconds hint for login/refresh JSON (default 86400).
# JWT_EXPIRES_IN=1d
# JWT_EXPIRES_IN_SEC=86400

# --- Email (optional) ---
# Without this, login still works; password reset / mail features just won’t send.
#
# Railway Free/Hobby: outbound SMTP (ports 465/587) is often BLOCKED — use Resend (HTTPS) instead:
#   1) Create account at https://resend.com → API Keys → copy key
#   2) Set RESEND_API_KEY=re_xxxx
#   3) Set RESEND_FROM=onboarding@resend.dev (testing) or Your Name <mail@your-verified-domain.com>
#
# Resend + onboarding@resend.dev (test sender): you can ONLY send to your Resend account email in To/CC/BCC.
# If Send fails with "only send testing emails...", either put that email in To (and remove other addresses),
# or verify a domain at https://resend.com/domains and set RESEND_FROM to e.g. noreply@yourdomain.com
#
# If RESEND_API_KEY is set, the app uses Resend and ignores SMTP for sending.
# RESEND_API_KEY=
# RESEND_FROM=onboarding@resend.dev
# RESEND_FETCH_TIMEOUT_MS=20000
#
# RFQ emails: merge extra Reply-To addresses after the logged-in user's address (comma or semicolon).
# Multiple test/ops inboxes in one line, e.g.:
# MAIL_REPLY_TO_EXTRA=lwsit3@gapps.cityu.edu.hk,teammate@cityu.edu.hk,backup@gmail.com
#
# Seed / RFQ UI: five extra test supplier addresses (example.com — not deliverable; swap for real inboxes in dev).
# After DB seed, they appear under Suppliers and in RFQ BCC. To add to an existing DB: mysql ... < backend/add_rfq_test_supplier_emails.sql
# rfq-test-alpha@example.com, rfq-test-beta@example.com, rfq-test-gamma@example.com, rfq-test-delta@example.com, rfq-test-epsilon@example.com
#
# SMTP (works on local machine or hosts that allow SMTP egress; Gmail App Password = 16 chars, NO spaces)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# Optional: shorten SMTP wait (ms) on failure (default 20000 / 15000 / 45000).
# SMTP_CONNECTION_TIMEOUT_MS=20000
# SMTP_GREETING_TIMEOUT_MS=15000
# SMTP_SOCKET_TIMEOUT_MS=45000
